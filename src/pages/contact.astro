---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact | Lynecares Plomberie Liégeoise">
  <Navbar />
  
  <main>
    <section class="page-header">
      <div class="container text-center">
        <h1>Contactez-Nous</h1>
        <p>Une urgence ou un projet de rénovation ? Nous sommes à votre écoute.</p>
      </div>
    </section>

    <section class="container py-5">
      <div class="contact-wrapper">
        <div class="contact-info glass p-5">
          <h2>Nos Coordonnées</h2>
          <p>N'hésitez pas à nous contacter pour toute demande de devis ou d'intervention. Notre équipe vous répondra dans les plus brefs délais.</p>
          
          <div class="info-item">
            <div class="icon">📍</div>
            <div>
              <h3>Adresse</h3>
              <p>Rue de la plomberie 123<br>4000 Liège, Belgique</p>
            </div>
          </div>
          
          <div class="info-item">
            <div class="icon">📞</div>
            <div>
              <h3>Téléphone</h3>
              <p><a href="tel:+3200000000">+32 (0) 400 00 00</a><br><small>Disponible 24/7 pour les urgences</small></p>
            </div>
          </div>
          
          <div class="info-item">
            <div class="icon">✉️</div>
            <div>
              <h3>Email</h3>
              <p><a href="mailto:info@lynecares.be">info@lynecares.be</a></p>
            </div>
          </div>

          <div class="social-links mt-4">
            <p><strong>Suivez-nous :</strong></p>
            <a href="#" class="social-btn">Facebook</a>
            <a href="#" class="social-btn">Instagram</a>
          </div>
        </div>

        <div class="contact-form glass p-5">
          <h2>Envoyez-nous un message</h2>
          <form id="contactForm">
            <div class="form-group">
              <label for="name">Nom complet *</label>
              <input type="text" id="name" required>
            </div>
            
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" required>
            </div>
            
            <div class="form-group">
              <label for="phone">Téléphone</label>
              <input type="tel" id="phone">
            </div>
            
            <div class="form-group">
              <label for="service">Service concerné</label>
              <select id="service">
                <option value="urgence">Dépannage Urgence</option>
                <option value="installation">Installation Sanitaire</option>
                <option value="chauffage">Chauffage</option>
                <option value="renovation">Rénovation</option>
                <option value="autre">Autre demande</option>
              </select>
            </div>
            
            <div class="form-group">
              <label for="message">Votre message *</label>
              <textarea id="message" rows="5" required></textarea>
            </div>
            
            <button type="submit" class="btn-primary w-100">Envoyer le message</button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-header {
    background-color: var(--navy);
    color: white;
    padding: 150px 0 80px;
    text-align: center;
  }

  .page-header h1 {
    color: white;
    font-size: 3rem;
  }

  .page-header p {
    color: var(--cyan);
    font-size: 1.2rem;
  }

  .p-5 { padding: 40px; }

  .contact-wrapper {
    display: flex;
    gap: 40px;
    flex-wrap: wrap;
  }

  .contact-info, .contact-form {
    flex: 1;
    min-width: 300px;
  }

  .contact-info h2, .contact-form h2 {
    color: var(--navy);
    margin-bottom: 25px;
  }

  .info-item {
    display: flex;
    gap: 15px;
    margin-top: 25px;
  }

  .info-item .icon {
    font-size: 1.8rem;
    background: rgba(0, 168, 204, 0.1);
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
  }

  .info-item h3 {
    margin: 0 0 5px 0;
    font-size: 1.1rem;
  }

  .info-item p {
    margin: 0;
    color: #475569;
  }

  .social-btn {
    display: inline-block;
    padding: 8px 16px;
    background-color: var(--navy);
    color: white;
    border-radius: 6px;
    margin-right: 10px;
    font-size: 0.9rem;
  }

  .social-btn:hover {
    background-color: var(--cyan);
    color: white;
  }

  .form-group {
    margin-bottom: 20px;
  }

  .form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: var(--navy);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 12px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    font-family: inherit;
    font-size: 1rem;
    background-color: rgba(255, 255, 255, 0.9);
    transition: border-color 0.3s;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--cyan);
    box-shadow: 0 0 0 3px rgba(0, 168, 204, 0.1);
  }

  .w-100 {
    width: 100%;
  }

  @media (max-width: 768px) {
    .contact-wrapper { flex-direction: column; }
  }
</style>
