---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Plombier Urgence Liège | Lynecares" preloadImage="https://images.unsplash.com/photo-1585704032915-c3400ca199e7?ixlib=rb-4.0.3&fm=webp&fit=crop&w=2070&q=80">
  <Navbar />
  
  <main>
    <section class="hero">
      <div class="hero-overlay"></div>
      <div class="container hero-content">
        <div class="glass hero-box">
          <span class="badge">Intervention en 30 minutes</span>
          <h1>Plombier de Confiance à <span class="highlight">Liège</span></h1>
          <p>Dépannage d'urgence, installation sanitaire et entretien de chauffage. Une équipe d'experts à votre service 24/7 dans toute la province de Liège.</p>
          <div class="hero-btns">
            <a href="tel:0466265895" class="btn-primary call-btn">☎ Appeler Maintenant</a>
            <a href="/contact" class="btn-secondary">Demander un Devis</a>
          </div>
        </div>
      </div>
    </section>

    <section class="features container py-5">
      <div class="feature-card glass">
        <div class="icon">🚀</div>
        <h3>Rapidité</h3>
        <p>Intervention urgente en moins de 30 minutes à Liège et ses alentours.</p>
      </div>
      <div class="feature-card glass">
        <div class="icon">🏆</div>
        <h3>Expertise</h3>
        <p>Plus de 15 ans d'expérience dans la plomberie et le chauffage.</p>
      </div>
      <div class="feature-card glass">
        <div class="icon">💶</div>
        <h3>Prix Transparents</h3>
        <p>Devis gratuit et tarifs clairs avant chaque intervention. Pas de surprise.</p>
      </div>
    </section>

    <section class="services-preview py-5">
      <div class="container">
        <h2 class="section-title">Nos Services de Plomberie à Liège</h2>
        <div class="services-grid">
          <div class="service-item glass">
            <h3>Dépannage Urgence</h3>
            <p>Fuite d'eau, canalisation bouchée, panne de chauffe-eau. Nous intervenons rapidement pour sécuriser votre installation.</p>
            <a href="/services#depannage" class="read-more">Dépannage urgence plombier Liège &rarr;</a>
          </div>
          <div class="service-item glass">
            <h3>Installation Sanitaire</h3>
            <p>Rénovation complète de salle de bain, installation de WC, douches, baignoires et robinetterie moderne.</p>
            <a href="/services#installation" class="read-more">Installation sanitaire Liège &rarr;</a>
          </div>
          <div class="service-item glass">
            <h3>Chauffage</h3>
            <p>Entretien, réparation et remplacement de chaudières toutes marques. Optimisez votre consommation d'énergie.</p>
            <a href="/services#chauffage" class="read-more">Réparation chaudière Liège &rarr;</a>
          </div>
        </div>
      </div>
    </section>

    <!-- TRUST & STATS SECTION -->
    <section class="trust-stats py-5">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-box glass">
            <span class="stat-number">30<small>min</small></span>
            <span class="stat-label">Temps de réponse moyen à Liège</span>
          </div>
          <div class="stat-box glass">
            <span class="stat-number">15<small>ans</small></span>
            <span class="stat-label">D'expertise à votre service</span>
          </div>
          <div class="stat-box glass">
            <span class="stat-number">100<small>%</small></span>
            <span class="stat-label">Devis respectés, sans surprise</span>
          </div>
          <div class="stat-box glass">
            <span class="stat-number">24<small>/7</small></span>
            <span class="stat-label">Disponibilité garantie</span>
          </div>
        </div>
        
        <div class="certifications-banner mt-5 glass text-center">
          <h3>Nos Agréments & Garanties</h3>
          <div class="cert-logos">
            <div class="cert-item">
              <span class="cert-icon">🛡️</span>
              <span>Agréé Assurances</span>
            </div>
            <div class="cert-item">
              <span class="cert-icon">🔥</span>
              <span>Agréé Cerga (Gaz)</span>
            </div>
            <div class="cert-item">
              <span class="cert-icon">🛢️</span>
              <span>Cédicol (Mazout)</span>
            </div>
            <div class="cert-item">
              <span class="cert-icon">✅</span>
              <span>Entreprise Enregistrée</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- TESTIMONIALS SECTION -->
    <section class="testimonials py-5 bg-light">
      <div class="container">
        <div class="text-center mb-5">
          <h2 class="section-title">Avis de Nos Clients à Liège et Province</h2>
          <div class="stars" style="color: #fbbf24; font-size: 1.5rem;">★★★★★</div>
          <p>Noté 4.9/5 basé sur plus de 200 avis clients à Liège et province.</p>
        </div>
        
        <div class="testimonials-grid">
          <div class="review-card glass">
            <div class="review-header">
              <div class="avatar">M</div>
              <div>
                <strong>Marc D. (Liège)</strong>
                <div class="stars" style="color: #fbbf24;">★★★★★</div>
              </div>
            </div>
            <p>"Fuite d'eau impressionnante à 2h du matin. Le plombier est arrivé en 25 minutes et a colmaté la fuite. Le devis était clair dès le départ. Je recommande à 100% !"</p>
            <span class="review-service">Service : Dépannage Urgence</span>
          </div>
          
          <div class="review-card glass">
            <div class="review-header">
              <div class="avatar">S</div>
              <div>
                <strong>Sophie L. (Seraing)</strong>
                <div class="stars" style="color: #fbbf24;">★★★★★</div>
              </div>
            </div>
            <p>"Très professionnels. Ils ont utilisé une caméra pour trouver un bouchon récalcitrant dans mes canalisations sans devoir tout casser. Travail propre et rapide."</p>
            <span class="review-service">Service : Débouchage Caméra</span>
          </div>
          
          <div class="review-card glass">
            <div class="review-header">
              <div class="avatar">J</div>
              <div>
                <strong>Jean-Pol (Chaudfontaine)</strong>
                <div class="stars" style="color: #fbbf24;">★★★★★</div>
              </div>
            </div>
            <p>"Remplacement complet de notre vieille chaudière. Conseils excellents sur le choix du modèle, installation nickel et ils ont même nettoyé tout le chantier avant de partir."</p>
            <span class="review-service">Service : Installation Chauffage</span>
          </div>
        </div>
      </div>
    </section>

    <!-- SERVICE MAP AREA -->
    <section class="service-map py-5">
      <div class="container">
        <div class="map-flex glass">
          <div class="map-content">
            <h2>Notre Zone d'Intervention à Liège et Province</h2>
            <p>Notre position stratégique nous permet de couvrir l'ensemble de la province de Liège avec des délais records. Consultez notre <a href="/locations">liste complète des communes</a>.</p>
            <ul class="area-list mt-3">
              <li><span class="text-cyan">📍</span> <strong>&lt; 30 min :</strong> Liège Centre, Herstal, Seraing, Ans, Grâce-Hollogne</li>
              <li><span class="text-cyan">📍</span> <strong>&lt; 45 min :</strong> Verviers, Chaudfontaine, Visé, Flémalle, Waremme</li>
              <li><span class="text-cyan">📍</span> <strong>Sur RDV :</strong> Huy, Eupen, Aywaille, Hannut</li>
            </ul>
            <a href="/locations" class="btn-secondary mt-4" style="display:inline-block;">Voir votre commune</a>
          </div>
          <div class="map-visual">
            <div class="radar-map">
              <div class="pulse"></div>
              <div class="pin">Liège</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="faq-section container py-5">
      <h2 class="section-title">FAQ : Plombier Urgence à Liège</h2>
      <div class="faq-grid">
        <div class="faq-item glass">
          <h3>Quel est le délai d'intervention pour une urgence ?</h3>
          <p>À Liège et dans son agglomération, nous garantissons une arrivée en moins de 30 minutes grâce à notre équipe d'astreinte.</p>
        </div>
        <div class="faq-item glass">
          <h3>Combien coûte un dépannage ?</h3>
          <p>Nos tarifs sont 100% transparents. Le technicien évalue la situation sur place et fournit un devis exact avant toute manipulation. Pas de frais cachés.</p>
        </div>
        <div class="faq-item glass">
          <h3>Comment déboucher une canalisation sans casse ?</h3>
          <p>Nous utilisons des caméras d'inspection et des systèmes d'hydrocurage à haute pression qui nettoient en profondeur sans endommager les tuyaux.</p>
        </div>
      </div>


      <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [{
          "@type": "Question",
          "name": "Quel est le délai d'intervention pour une urgence ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "À Liège et dans son agglomération, nous garantissons une arrivée en moins de 30 minutes grâce à notre équipe d'astreinte."
          }
        }, {
          "@type": "Question",
          "name": "Combien coûte un dépannage ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nos tarifs sont 100% transparents. Le technicien évalue la situation sur place et fournit un devis exact avant toute manipulation. Pas de frais cachés."
          }
        }, {
          "@type": "Question",
          "name": "Comment déboucher une canalisation sans casse ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nous utilisons des caméras d'inspection et des systèmes d'hydrocurage à haute pression qui nettoient en profondeur sans endommager les tuyaux."
          }
        }]
      }
      </script>
    </section>

    <section class="cta py-5">
      <div class="container cta-container glass">
        <h2>Une Urgence Plomberie ?</h2>
        <p>Nos techniciens sont prêts à intervenir immédiatement, de jour comme de nuit.</p>
        <a href="tel:0466265895" class="btn-primary cta-btn">Contactez l'assistance (24/7)</a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .hero {
    min-height: 100vh;
    background: linear-gradient(rgba(27, 42, 74, 0.7), rgba(27, 42, 74, 0.8)), url('https://images.unsplash.com/photo-1585704032915-c3400ca199e7?ixlib=rb-4.0.3&fm=webp&fit=crop&w=2070&q=80') center/cover;
    display: flex;
    align-items: center;
    position: relative;
    padding-top: 80px;
  }

  .hero-box {
    max-width: 650px;
    padding: 40px;
    animation: slideUp 0.8s ease-out;
  }

  .badge {
    background-color: var(--orange);
    color: white;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    display: inline-block;
    margin-bottom: 20px;
  }

  .hero h1 {
    font-size: 3.5rem;
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .highlight {
    color: var(--cyan);
  }

  .hero p {
    font-size: 1.2rem;
    margin-bottom: 30px;
    color: #475569;
  }

  .hero-btns {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
  }

  .call-btn {
    background-color: var(--orange);
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
    margin-top: -60px;
    position: relative;
    z-index: 10;
  }

  .feature-card {
    padding: 30px;
    text-align: center;
    transition: transform 0.3s ease;
  }

  .feature-card:hover {
    transform: translateY(-10px);
  }

  .feature-card .icon {
    font-size: 3rem;
    margin-bottom: 15px;
  }

  .services-preview {
    background-color: white;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 30px;
  }

  .service-item {
    padding: 40px;
    border-top: 5px solid var(--cyan);
  }

  .read-more {
    display: inline-block;
    margin-top: 15px;
    font-weight: 600;
  }

  .cta-container {
    background: linear-gradient(135deg, var(--navy), #2a4175);
    color: white;
    text-align: center;
    padding: 60px 40px;
    border: none;
  }

  .cta-container h2 {
    color: white;
  }

  .cta-btn {
    background-color: var(--orange);
    font-size: 1.2rem;
    padding: 15px 40px;
    margin-top: 20px;
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .hero h1 { font-size: 2.5rem; }
    .features { margin-top: 40px; }
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
  }

  .faq-item {
    padding: 30px;
    border-left: 4px solid var(--orange);
  }

  .faq-item h3 {
    color: var(--navy);
    margin-bottom: 15px;
    font-size: 1.1rem;
  }

  .faq-item p {
    color: #475569;
    margin: 0;
  }

  /* NEW SECTIONS STYLES */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
  }

  .stat-box {
    padding: 30px 20px;
    text-align: center;
    border-top: 4px solid var(--orange);
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 800;
    color: var(--navy);
    line-height: 1;
    margin-bottom: 10px;
  }

  .stat-number small {
    font-size: 1.2rem;
    color: var(--cyan);
  }

  .stat-label {
    font-weight: 600;
    color: #475569;
  }

  .certifications-banner {
    padding: 30px;
  }

  .certifications-banner h3 {
    color: var(--navy);
    margin-bottom: 20px;
  }

  .cert-logos {
    display: flex;
    justify-content: center;
    gap: 30px;
    flex-wrap: wrap;
  }

  .cert-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    color: var(--navy);
  }

  .cert-icon {
    font-size: 2.5rem;
  }

  .bg-light {
    background-color: white;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
  }

  .review-card {
    padding: 30px;
    border-left: 4px solid var(--cyan);
  }

  .review-header {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 15px;
  }

  .avatar {
    width: 50px;
    height: 50px;
    background-color: var(--navy);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: bold;
  }

  .review-card p {
    font-style: italic;
    color: #475569;
    margin-bottom: 15px;
  }

  .review-service {
    font-size: 0.85rem;
    color: var(--orange);
    font-weight: 600;
  }

  .map-flex {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    padding: 40px;
    align-items: center;
    background-color: white;
    border-top: 4px solid var(--navy);
  }

  .area-list {
    list-style: none;
    padding: 0;
  }

  .area-list li {
    padding: 10px 0;
    border-bottom: 1px solid #e2e8f0;
  }

  .area-list li:last-child {
    border-bottom: none;
  }

  .text-cyan {
    color: var(--cyan);
  }

  .map-visual {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 300px;
    background: #f8fafc;
    border-radius: 12px;
    position: relative;
    overflow: hidden;
  }

  .radar-map {
    position: relative;
    width: 200px;
    height: 200px;
  }

  .pulse {
    position: absolute;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 168, 204, 0.2);
    border-radius: 50%;
    animation: radarPulse 2s infinite ease-out;
  }

  .pin {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--navy);
    color: white;
    padding: 10px 20px;
    border-radius: 20px;
    font-weight: bold;
    z-index: 2;
  }

  @keyframes radarPulse {
    0% { transform: scale(0.1); opacity: 1; }
    100% { transform: scale(1.5); opacity: 0; }
  }

  @media (max-width: 768px) {
    .map-flex {
      grid-template-columns: 1fr;
    }
  }
</style>
