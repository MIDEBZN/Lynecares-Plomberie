---

<Layout title="Blog Plomberie Liège | Conseils et Astuces Lynecares" description="Découvrez tous nos articles, conseils et guides sur la plomberie, le chauffage et les législations sanitaires en province de Liège.">
  <Navbar />
  
  <main>
    <section class="page-header">
      <div class="container text-center">
        <h1>Le Blog Plomberie & Chauffage</h1>
        <p>Expertise, conseils et actualités de la plomberie liégeoise</p>
      </div>
    </section>

    <section class="blog-list py-5">
      <div class="container">
        <div class="grid">
          {articles.map(article => (
            <article class="blog-card glass">
              <span class="category-badge">{article.category}</span>
              <h2><a href={article.url}>{article.title}</a></h2>
              <p>{article.excerpt}</p>
              <a href={article.url} class="read-more">Lire l'article &rarr;</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-header {
    background-color: var(--navy);
    color: white;
    padding: 120px 0 60px;
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 15px;
    color: white;
  }

  .page-header p {
    font-size: 1.2rem;
    color: var(--cyan);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 30px;
  }

  .blog-card {
    padding: 30px;
    border-radius: 12px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  .category-badge {
    background-color: var(--cyan);
    color: white;
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: bold;
    display: inline-block;
    margin-bottom: 15px;
    align-self: flex-start;
  }

  .blog-card h2 {
    font-size: 1.3rem;
    margin-bottom: 15px;
    line-height: 1.4;
  }

  .blog-card h2 a {
    color: var(--navy);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .blog-card h2 a:hover {
    color: var(--orange);
  }

  .blog-card p {
    color: #475569;
    font-size: 0.95rem;
    margin-bottom: 20px;
    flex-grow: 1;
  }

  .read-more {
    color: var(--orange);
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition: transform 0.3s ease;
  }

  .read-more:hover {
    transform: translateX(5px);
  }
</style>
