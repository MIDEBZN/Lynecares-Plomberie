---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Plomberie Liégeoise - Expert plumbing services in Liège. Dépannage, installation, and maintenance." } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Lynecares Plomberie</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&display=swap" rel="stylesheet">
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "Plumber",
			"name": "Lynecares Plomberie Liégeoise",
			"image": "https://lynecares-plomberie.vercel.app/logo.png",
			"@id": "https://lynecares-plomberie.vercel.app",
			"url": "https://lynecares-plomberie.vercel.app",
			"telephone": "+32400000000",
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "Rue de la plomberie 123",
				"addressLocality": "Liège",
				"postalCode": "4000",
				"addressCountry": "BE"
			},
			"geo": {
				"@type": "GeoCoordinates",
				"latitude": 50.632557,
				"longitude": 5.579666
			},
			"openingHoursSpecification": {
				"@type": "OpeningHoursSpecification",
				"dayOfWeek": [
					"Monday",
					"Tuesday",
					"Wednesday",
					"Thursday",
					"Friday",
					"Saturday",
					"Sunday"
				],
				"opens": "00:00",
				"closes": "23:59"
			},
			"priceRange": "€€",
			"description": "Plombier chauffagiste de confiance à Liège. Intervention d'urgence 24/7 en moins de 30 minutes, tarifs transparents sans surprise."
		}
		</script>
	</head>
	<body>
		<slot />
	</body>
</html>
